{
  "expo": {
    "name": "AuExpert",
    "slug": "auexpert",
    "scheme": "auexpert",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon_app_ok.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/icon_app_ok.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F1923"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.auexpert.app",
      "associatedDomains": [
        "applinks:multiversodigital.com.br"
      ],
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Permitir que AuExpert acesse o microfone para transcrever sua voz.",
        "NSSpeechRecognitionUsageDescription": "Permitir que AuExpert use o reconhecimento de fala para transcrever o que você diz.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.auexpert.app",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "multiversodigital.com.br",
              "pathPrefix": "/auexpert/invite"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ],
      "adaptiveIcon": {
        "backgroundColor": "#0F1923",
        "foregroundImage": "./assets/images/icon_app_ok.png"
      },
      "splash": {
        "image": "./assets/images/icon_app_ok.png",
        "resizeMode": "contain",
        "backgroundColor": "#0F1923"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0F1923",
          "image": "./assets/images/icon_app_ok.png",
          "imageWidth": 220
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Permitir que AuExpert acesse sua câmera para análise de fotos do pet."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon_app_ok.png",
          "color": "#E8813A"
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Permitir que AuExpert use o Face ID para login rápido."
        }
      ],
      "expo-localization",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Permitir que AuExpert acesse o microfone para transcrever sua voz.",
          "speechRecognitionPermission": "Permitir que AuExpert use o reconhecimento de fala para transcrever o que você diz."
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Permitir que AuExpert acesse o microfone para gravar sons do seu pet."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Permitir que AuExpert acesse suas fotos para análise e perfil do pet.",
          "cameraPermission": "Permitir que AuExpert acesse sua câmera para análise de fotos do pet."
        }
      ],
      "expo-sharing",
      "expo-sqlite"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "258d535c-fa78-4aa1-a5cf-29ebbe499aec"
      }
    },
    "owner": "abreuretto"
  }
}
