{
  "expo": {
    "name": "AuExpert",
    "slug": "auexpert",
    "scheme": "auexpert",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon_app_ok.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/icon_app_ok.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F1923"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.auexpert.app",
      "associatedDomains": [
        "applinks:multiversodigital.com.br"
      ],
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Allow AuExpert to access the microphone to transcribe your voice and record sounds from your pet.",
        "NSSpeechRecognitionUsageDescription": "Allow AuExpert to use speech recognition to transcribe what you say.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "locales": {
        "pt-BR": "./locales/pt-BR.json"
      }
    },
    "android": {
      "package": "com.auexpert.app",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "multiversodigital.com.br",
              "pathPrefix": "/auexpert/invite"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ],
      "adaptiveIcon": {
        "backgroundColor": "#0F1923",
        "foregroundImage": "./assets/images/icon_app_ok.png"
      },
      "splash": {
        "image": "./assets/images/icon_app_ok.png",
        "resizeMode": "contain",
        "backgroundColor": "#0F1923"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0F1923",
          "image": "./assets/images/icon_app_ok.png",
          "imageWidth": 220
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow AuExpert to access your camera to analyze photos of your pet."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon_app_ok.png",
          "color": "#E8813A"
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow AuExpert to use Face ID for fast and secure sign-in."
        }
      ],
      "expo-localization",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow AuExpert to access the microphone to transcribe your voice.",
          "speechRecognitionPermission": "Allow AuExpert to use speech recognition to transcribe what you say."
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Allow AuExpert to access the microphone to record sounds from your pet."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow AuExpert to access your photos for pet analysis and profile.",
          "cameraPermission": "Allow AuExpert to access your camera to analyze photos of your pet."
        }
      ],
      "expo-sharing",
      "expo-sqlite"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "258d535c-fa78-4aa1-a5cf-29ebbe499aec"
      }
    },
    "owner": "abreuretto"
  }
}
